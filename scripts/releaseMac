#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROJECT_PATH="${ROOT_DIR}/AvdBuddy.xcodeproj"
SCHEME="AvdBuddy"
ENV_FILE="${ROOT_DIR}/.env"
ENV_FILE_ENC="${ROOT_DIR}/.env.enc"
DEFAULT_RELEASE_REPO="alexstyl/avdbuddy"
DEFAULT_OUTPUT_DIR="${ROOT_DIR}/output"
CHANGELOG_PATH="${ROOT_DIR}/CHANGELOG.md"
SPARKLE_APPCAST_TOOL_PATH="${ROOT_DIR}/.derivedData/sparkle-tools/Build/Products/Release/generate_appcast"

load_env_file() {
  if [[ -f "${ENV_FILE}" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "${ENV_FILE}"
    set +a
    return 0
  fi

  if [[ -f "${ENV_FILE_ENC}" ]]; then
    require_cmd sops
    set -a
    # shellcheck disable=SC1090
    source <(sops decrypt --input-type dotenv --output-type dotenv "${ENV_FILE_ENC}")
    set +a
  fi
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "error: Missing command: $1" >&2
    exit 1
  fi
}

build_generate_appcast_tool() {
  local sparkle_checkout_dir="$1"
  local tool_derived_data="${ROOT_DIR}/.derivedData/sparkle-tools"

  [[ -d "${sparkle_checkout_dir}" ]] || fail "Sparkle checkout not found at ${sparkle_checkout_dir}"

  echo "==> Building Sparkle appcast tool" >&2
  (
    cd "${sparkle_checkout_dir}"
    /usr/bin/xcodebuild \
      -scheme generate_appcast \
      -configuration Release \
      -derivedDataPath "${tool_derived_data}" \
      -destination "platform=macOS" \
      build >/dev/null
  )

  [[ -x "${SPARKLE_APPCAST_TOOL_PATH}" ]] || fail "generate_appcast not found at ${SPARKLE_APPCAST_TOOL_PATH}"
}

ensure_clean_worktree() {
  if [[ -n "$(git status --short --untracked-files=no)" ]]; then
    fail "release requires a clean git worktree"
  fi
}

extract_unreleased_changelog() {
  local changelog_path="$1"

  awk '
    $0 == "## Unreleased" { capture = 1; next }
    capture && /^## / { capture = 0; exit }
    capture { lines[++count] = $0 }
    END {
      start = 1
      while (start <= count && lines[start] ~ /^[[:space:]]*$/) {
        start++
      }

      end = count
      while (end >= start && lines[end] ~ /^[[:space:]]*$/) {
        end--
      }

      for (i = start; i <= end; i++) {
        print lines[i]
      }
    }
  ' "${changelog_path}"
}

promote_changelog_release() {
  local changelog_path="$1"
  local version="$2"
  local release_date="$3"
  local release_notes_path="$4"
  local temp_path

  temp_path="$(mktemp)"

  awk -v version="${version}" -v release_date="${release_date}" -v release_notes_path="${release_notes_path}" '
    BEGIN { state = 0 }
    {
      if (state == 0) {
        print
        if ($0 == "## Unreleased") {
          print ""
          printf "## [%s] - %s\n", version, release_date
          print ""

          while ((getline note_line < release_notes_path) > 0) {
            print note_line
          }
          close(release_notes_path)
          print ""
          state = 1
        }
        next
      }

      if (state == 1) {
        if ($0 ~ /^## /) {
          print
          state = 2
        }
        next
      }

      print
    }
  ' "${changelog_path}" > "${temp_path}"

  /bin/mv "${temp_path}" "${changelog_path}"
}

prepare_release_notes() {
  local version="$1"
  local release_date="$2"
  local release_notes_path="$3"

  [[ -f "${CHANGELOG_PATH}" ]] || fail "CHANGELOG.md not found at ${CHANGELOG_PATH}"
  rg '^## Unreleased$' "${CHANGELOG_PATH}" >/dev/null || fail "CHANGELOG.md is missing the '## Unreleased' heading"

  extract_unreleased_changelog "${CHANGELOG_PATH}" > "${release_notes_path}"
  [[ -s "${release_notes_path}" ]] || fail "CHANGELOG.md has no unreleased notes to ship"

  promote_changelog_release "${CHANGELOG_PATH}" "${version}" "${release_date}" "${release_notes_path}"
}

commit_release_changelog() {
  local version="$1"

  git add "${CHANGELOG_PATH}"
  git commit -m "Release ${version}"
}

push_release_commit_and_tag() {
  local tag_name="$1"
  local current_branch

  current_branch="$(git rev-parse --abbrev-ref HEAD)"
  [[ "${current_branch}" != "HEAD" ]] || fail "release requires a branch checkout, not detached HEAD"
  if git rev-parse -q --verify "refs/tags/${tag_name}" >/dev/null; then
    fail "local tag ${tag_name} already exists"
  fi

  git tag "${tag_name}"
  git push origin "HEAD:${current_branch}"
  git push origin "refs/tags/${tag_name}"
}

fail() {
  echo "error: $*" >&2
  exit 1
}

normalize_semver() {
  local raw="$1"
  local normalized="${raw#v}"
  if [[ "${normalized}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    printf "%s\n" "${normalized}"
    return 0
  fi
  return 1
}

semver_gt() {
  local left="$1"
  local right="$2"
  local sorted
  sorted="$(printf "%s\n%s\n" "${left}" "${right}" | sort -V)"
  local first
  first="$(printf "%s\n" "${sorted}" | head -n1)"
  [[ "${first}" == "${right}" && "${left}" != "${right}" ]]
}

build_from_version() {
  local version="$1"
  local major minor patch
  IFS='.' read -r major minor patch <<<"${version}"
  printf "%d\n" "$((major * 10000 + minor * 100 + patch))"
}

latest_remote_semver_tag() {
  local remote_url="git@github.com:${RELEASE_REPO}.git"
  git ls-remote --tags --refs "${remote_url}" \
    | awk '{print $2}' \
    | sed 's#refs/tags/##' \
    | sed 's/^v//' \
    | rg '^[0-9]+\.[0-9]+\.[0-9]+$' \
    | sort -V \
    | tail -n1
}

remote_tag_exists() {
  local tag="$1"
  local remote_url="git@github.com:${RELEASE_REPO}.git"
  [[ -n "$(git ls-remote --tags --refs "${remote_url}" "refs/tags/${tag}")" ]]
}

usage() {
  cat <<'EOF'
Usage:
  scripts/releaseMac [--version <x.y.z>] [--build <number>] [options]

Versioning:
  --version, --v <value> Marketing version (CFBundleShortVersionString), e.g. 1.2.3
  --build <value>        Optional build number override (CFBundleVersion)

Optional:
  --repo <owner/name>    GitHub repo for release assets (default: alexstyl/avdbuddy)
  --notes-file <path>    Optional markdown file to attach to Sparkle release notes
  --output-dir <path>    Output directory for artifacts
  --dry-run              Build and package locally, but do not publish
  --skip-gh-release      Skip GitHub release creation/upload
  --skip-notarization    Skip notarization and stapling
  -h, --help             Show this help

Environment:
  .env or .env.enc may provide:
    GITHUB_TOKEN / GH_TOKEN
    RELEASE_REPO
    NOTARY_APPLE_ID
    NOTARY_TEAM_ID
    NOTARY_PASSWORD
    RELEASE_SIGN_IDENTITY
EOF
}

load_env_file

VERSION=""
BUILD_OVERRIDE=""
RELEASE_REPO="${RELEASE_REPO:-${DEFAULT_RELEASE_REPO}}"
OUTPUT_DIR="${DEFAULT_OUTPUT_DIR}"
NOTES_FILE=""
DRY_RUN=false
SKIP_GH_RELEASE=false
SKIP_NOTARIZATION=false
NOTARY_APPLE_ID="${NOTARY_APPLE_ID:-}"
NOTARY_TEAM_ID="${NOTARY_TEAM_ID:-}"
NOTARY_PASSWORD="${NOTARY_PASSWORD:-}"
RELEASE_SIGN_IDENTITY="${RELEASE_SIGN_IDENTITY:-}"
GITHUB_TOKEN_CONFIG="${GITHUB_TOKEN:-${GH_TOKEN:-}}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --version|--v)
      VERSION="${2:-}"
      shift 2
      ;;
    --build)
      BUILD_OVERRIDE="${2:-}"
      shift 2
      ;;
    --repo)
      RELEASE_REPO="${2:-}"
      shift 2
      ;;
    --notes-file)
      NOTES_FILE="${2:-}"
      shift 2
      ;;
    --output-dir)
      OUTPUT_DIR="${2:-}"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    --skip-gh-release)
      SKIP_GH_RELEASE=true
      shift
      ;;
    --skip-notarization)
      SKIP_NOTARIZATION=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      fail "Unknown argument: $1"
      ;;
  esac
done

[[ -f "${PROJECT_PATH}/project.pbxproj" ]] || fail "Xcode project not found: ${PROJECT_PATH}"
if [[ -n "${NOTES_FILE}" && ! -f "${NOTES_FILE}" ]]; then
  fail "--notes-file not found: ${NOTES_FILE}"
fi

require_cmd xcodebuild
require_cmd git
require_cmd ditto
require_cmd xcrun
require_cmd rg
require_cmd create-dmg

if [[ "${DRY_RUN}" == false && "${SKIP_GH_RELEASE}" == false ]]; then
  require_cmd gh
fi

if [[ -n "${GITHUB_TOKEN_CONFIG}" ]]; then
  export GITHUB_TOKEN="${GITHUB_TOKEN_CONFIG}"
  export GH_TOKEN="${GITHUB_TOKEN_CONFIG}"
fi

LATEST_VERSION="$(latest_remote_semver_tag || true)"

if [[ -z "${VERSION}" ]]; then
  if [[ -n "${LATEST_VERSION}" ]]; then
    read -r -p "What version do you want to ship? (last version was ${LATEST_VERSION}): " VERSION
  else
    read -r -p "What version do you want to ship? (no previous semver tag found): " VERSION
  fi
fi

VERSION="$(normalize_semver "${VERSION}")" || fail "--version must look like x.y.z (optionally prefixed with v)"

if [[ -n "${LATEST_VERSION}" ]] && semver_gt "${LATEST_VERSION}" "${VERSION}"; then
  fail "version ${VERSION} must be greater than or equal to latest tag ${LATEST_VERSION}"
fi

if remote_tag_exists "${VERSION}"; then
  fail "version ${VERSION} has already been released (tag exists)"
fi

BUILD="$(build_from_version "${VERSION}")"
if [[ -n "${BUILD_OVERRIDE}" ]]; then
  [[ "${BUILD_OVERRIDE}" =~ ^[0-9]+$ ]] || fail "--build must be an integer"
  BUILD="${BUILD_OVERRIDE}"
fi

if [[ "${DRY_RUN}" == false && "${SKIP_GH_RELEASE}" == false ]]; then
  ensure_clean_worktree
fi

mkdir -p "${OUTPUT_DIR}"
DERIVED_DATA="${ROOT_DIR}/.derivedData/release-${VERSION}-${BUILD}"
ARCHIVE_NAME="AvdBuddy-${VERSION}"
APP_NAME="AvdBuddy.app"
APP_PATH="${DERIVED_DATA}/Build/Products/Release/${APP_NAME}"
SPARKLE_CHECKOUT_DIR="${DERIVED_DATA}/SourcePackages/checkouts/Sparkle"
DMG_STAGING_DIR="${DERIVED_DATA}/dmg-staging"
DMG_OUTPUT_DIR="${DERIVED_DATA}/dmg-output"
APPCAST_STAGING_DIR="${DERIVED_DATA}/appcast-staging"
STAGED_APP_PATH="${DMG_STAGING_DIR}/${APP_NAME}"
DMG_PATH="${OUTPUT_DIR}/${ARCHIVE_NAME}.dmg"
STABLE_DMG_NAME="AvdBuddy.dmg"
STABLE_DMG_PATH="${OUTPUT_DIR}/${STABLE_DMG_NAME}"
APPCAST_PATH="${OUTPUT_DIR}/appcast.xml"
RELEASE_NOTES_PATH="${DERIVED_DATA}/release-notes.md"
RELEASE_DATE="$(date '+%Y-%m-%d')"
TAG_NAME="${VERSION}"
TITLE="AvdBuddy ${VERSION} (${BUILD})"

if [[ -n "${NOTES_FILE}" ]]; then
  /bin/mkdir -p "${DERIVED_DATA}"
  /bin/cp -f "${NOTES_FILE}" "${RELEASE_NOTES_PATH}"
elif [[ "${DRY_RUN}" == false && "${SKIP_GH_RELEASE}" == false ]]; then
  /bin/mkdir -p "${DERIVED_DATA}"
  prepare_release_notes "${VERSION}" "${RELEASE_DATE}" "${RELEASE_NOTES_PATH}"
fi

echo "==> Building macOS app"
echo "    version: ${VERSION}"
echo "    build:   ${BUILD}"
echo "    derived: ${DERIVED_DATA}"

XCODEBUILD_ARGS=(
  -project "${PROJECT_PATH}"
  -scheme "${SCHEME}"
  -configuration Release
  -destination "platform=macOS"
  -derivedDataPath "${DERIVED_DATA}"
  "MARKETING_VERSION=${VERSION}"
  "CURRENT_PROJECT_VERSION=${BUILD}"
  build
)

if [[ "${DRY_RUN}" == true ]]; then
  XCODEBUILD_ARGS+=(
    CODE_SIGNING_ALLOWED=NO
    CODE_SIGNING_REQUIRED=NO
  )
else
  XCODEBUILD_ARGS+=(
    CODE_SIGN_INJECT_BASE_ENTITLEMENTS=NO
    DEPLOYMENT_POSTPROCESSING=YES
    STRIP_INSTALLED_PRODUCT=YES
    COPY_PHASE_STRIP=YES
    "OTHER_CODE_SIGN_FLAGS=--timestamp"
  )
  if [[ -z "${RELEASE_SIGN_IDENTITY}" ]]; then
    RELEASE_SIGN_IDENTITY="$(
      security find-identity -v -p codesigning \
        | sed -n 's/^[[:space:]]*[0-9][0-9]*)[[:space:]][0-9A-F]\{40\}[[:space:]]*"\(Developer ID Application:.*\)".*/\1/p' \
        | head -n1
    )"
  fi
  [[ -n "${RELEASE_SIGN_IDENTITY}" ]] || fail "No Developer ID Application identity found"
  [[ "${RELEASE_SIGN_IDENTITY}" == Developer\ ID\ Application:* ]] || fail "RELEASE_SIGN_IDENTITY must be a Developer ID Application certificate"
  RELEASE_TEAM_ID="${NOTARY_TEAM_ID}"
  if [[ -z "${RELEASE_TEAM_ID}" && "${RELEASE_SIGN_IDENTITY}" =~ \(([A-Z0-9]{10})\)$ ]]; then
    RELEASE_TEAM_ID="${BASH_REMATCH[1]}"
  fi
  [[ -n "${RELEASE_TEAM_ID}" ]] || fail "Could not determine DEVELOPMENT_TEAM for release signing"
  XCODEBUILD_ARGS+=(
    CODE_SIGN_STYLE=Manual
    "CODE_SIGN_IDENTITY=${RELEASE_SIGN_IDENTITY}"
    "DEVELOPMENT_TEAM=${RELEASE_TEAM_ID}"
  )
fi

/usr/bin/xcodebuild "${XCODEBUILD_ARGS[@]}"

[[ -d "${APP_PATH}" ]] || fail "Built app not found at ${APP_PATH}"

echo "==> Preparing release artifact"
/bin/rm -rf "${DMG_STAGING_DIR}" "${DMG_OUTPUT_DIR}"
/bin/mkdir -p "${DMG_STAGING_DIR}" "${DMG_OUTPUT_DIR}"
/usr/bin/ditto "${APP_PATH}" "${STAGED_APP_PATH}"

echo "==> Creating DMG"
/bin/rm -f "${DMG_PATH}"
CREATE_DMG_ARGS=(
  --overwrite
  --dmg-title "AvdBuddy"
)
if [[ "${DRY_RUN}" == false ]]; then
  CREATE_DMG_ARGS+=("--identity=${RELEASE_SIGN_IDENTITY}")
fi
create-dmg \
  "${CREATE_DMG_ARGS[@]}" \
  "${STAGED_APP_PATH}" \
  "${DMG_OUTPUT_DIR}" >/dev/null
GENERATED_DMG_PATH="$(find "${DMG_OUTPUT_DIR}" -maxdepth 1 -type f -name '*.dmg' | head -n1)"
[[ -n "${GENERATED_DMG_PATH}" ]] || fail "create-dmg did not produce a DMG"
/bin/mv -f "${GENERATED_DMG_PATH}" "${DMG_PATH}"

if [[ "${DRY_RUN}" == false && "${SKIP_NOTARIZATION}" == false ]]; then
  [[ -n "${NOTARY_APPLE_ID}" ]] || fail "NOTARY_APPLE_ID is required"
  [[ -n "${NOTARY_TEAM_ID}" ]] || fail "NOTARY_TEAM_ID is required"
  [[ -n "${NOTARY_PASSWORD}" ]] || fail "NOTARY_PASSWORD is required"

  echo "==> Notarizing DMG"
  xcrun notarytool submit "${DMG_PATH}" \
    --apple-id "${NOTARY_APPLE_ID}" \
    --team-id "${NOTARY_TEAM_ID}" \
    --password "${NOTARY_PASSWORD}" \
    --wait

  echo "==> Stapling DMG"
  xcrun stapler staple "${DMG_PATH}"
  xcrun stapler validate "${DMG_PATH}" >/dev/null
fi

echo "    dmg: ${DMG_PATH}"

echo "==> Generating Sparkle appcast"
/bin/rm -rf "${APPCAST_STAGING_DIR}"
/bin/mkdir -p "${APPCAST_STAGING_DIR}"
/bin/cp -f "${DMG_PATH}" "${STABLE_DMG_PATH}"
/bin/cp -f "${STABLE_DMG_PATH}" "${APPCAST_STAGING_DIR}/${STABLE_DMG_NAME}"
if [[ -f "${RELEASE_NOTES_PATH}" ]]; then
  /bin/cp -f "${RELEASE_NOTES_PATH}" "${APPCAST_STAGING_DIR}/AvdBuddy.md"
fi
build_generate_appcast_tool "${SPARKLE_CHECKOUT_DIR}"
GENERATE_APPCAST_ARGS=(
  --account avdbuddy
  --maximum-versions 1
  --download-url-prefix "https://github.com/${RELEASE_REPO}/releases/latest/download/"
  --link "https://github.com/${RELEASE_REPO}"
  --embed-release-notes
  -o "${APPCAST_STAGING_DIR}/appcast.xml"
  "${APPCAST_STAGING_DIR}"
)
if ! "${SPARKLE_APPCAST_TOOL_PATH}" "${GENERATE_APPCAST_ARGS[@]}" >/dev/null; then
  echo "==> Retrying Sparkle appcast generation" >&2
  "${SPARKLE_APPCAST_TOOL_PATH}" "${GENERATE_APPCAST_ARGS[@]}" || fail "generate_appcast failed"
fi
/bin/cp -f "${APPCAST_STAGING_DIR}/appcast.xml" "${APPCAST_PATH}"

echo "    sparkle dmg: ${STABLE_DMG_PATH}"
echo "    appcast:     ${APPCAST_PATH}"

if [[ "${DRY_RUN}" == true || "${SKIP_GH_RELEASE}" == true ]]; then
  echo "==> Skipping GitHub release publish"
  exit 0
fi

if [[ -z "${NOTES_FILE}" ]]; then
  commit_release_changelog "${VERSION}"
fi
push_release_commit_and_tag "${TAG_NAME}"

echo "==> Verifying GitHub auth"
gh auth status >/dev/null

RELEASE_BODY="Automated macOS release for AvdBuddy."
if [[ -f "${RELEASE_NOTES_PATH}" ]]; then
  RELEASE_BODY="$(cat "${RELEASE_NOTES_PATH}")"
fi

echo "==> Publishing GitHub release"
if gh release view "${TAG_NAME}" --repo "${RELEASE_REPO}" >/dev/null 2>&1; then
  gh release upload "${TAG_NAME}" \
    "${DMG_PATH}" \
    "${STABLE_DMG_PATH}" \
    "${APPCAST_PATH}" \
    --clobber \
    --repo "${RELEASE_REPO}"
else
  gh release create "${TAG_NAME}" \
    "${DMG_PATH}" \
    "${STABLE_DMG_PATH}" \
    "${APPCAST_PATH}" \
    --title "${TITLE}" \
    --notes "${RELEASE_BODY}" \
    --repo "${RELEASE_REPO}"
fi

echo "==> Release completed"
echo "    repo: ${RELEASE_REPO}"
echo "    tag:  ${TAG_NAME}"
